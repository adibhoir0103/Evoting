# ============================================
# Bharat E-Vote Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# ============ Supabase ============
VITE_SUPABASE_URL="https://xxxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ============ Backend API ============
# Local dev: use relative path (Vite proxy forwards to localhost:5000)
VITE_API_URL="/api/v1"
# Production: use full URL of your deployed backend
# VITE_API_URL="https://your-backend.onrender.com/api/v1"

# ============ Sentry Error Monitoring ============
VITE_SENTRY_DSN="https://xxx@xxx.ingest.us.sentry.io/xxx"

# ============ PostHog Analytics ============
VITE_POSTHOG_KEY="phc_xxxxxxxxxxxx"
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# ============ Cloudflare Turnstile (Bot Protection) ============
VITE_TURNSTILE_SITE_KEY="0x4AAAAAxxxxxxxxxx"
