# ============================================================
# Bharat E-Vote — Hardhat Deployment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Sepolia Testnet RPC URL (from Alchemy, Infura, etc.)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY"

# Root Environment Variables (Blockchain / Hardhat Scope)
# IMPORTANT: For the complete API, DB, and Auth environment variables,
# see the separate `backend/.env.example` file.
# ----------------------------------------------------------------------
# Deployer wallet private key (WITHOUT 0x prefix)
# NEVER use a wallet with real mainnet funds for testing
PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"
