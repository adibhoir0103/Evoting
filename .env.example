# ============================================================
# Bharat E-Vote — Comprehensive Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# To generate a secure JWT secret or Aadhaar Pepper:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# To generate admin password hash:
#   node -e "require('bcrypt').hash('YOUR_STRONG_PASSWORD', 12).then(console.log)"
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://username:password@localhost:5432/evoting?schema=public"

# --- Authentication ---
JWT_SECRET=""
AADHAAR_PEPPER=""

# --- Admin Credentials ---
ADMIN_EMAIL="admin@evote.com"
ADMIN_PASSWORD_HASH=""

# --- Bot Protection (Cloudflare Turnstile) ---
TURNSTILE_SECRET_KEY=""

# --- Session Store (Upstash Redis) ---
# Sign up: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Email Service (Brevo) ---
# Sign up: https://app.brevo.com/
# Get API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
BREVO_FROM_EMAIL="no-reply@your-domain.com"
BREVO_FROM_NAME="Bharat E-Vote"

# --- IPFS Storage (Pinata) ---
# Sign up: https://app.pinata.cloud/
PINATA_API_KEY=""
PINATA_SECRET_KEY=""
PINATA_JWT=""

# --- Error Monitoring (Sentry) ---
SENTRY_DSN=""

# --- Environment ---
NODE_ENV="development"
PORT=5000

# ============================================================
# Blockchain Deployment Configuration
# ============================================================
# Deployer wallet private key (WITHOUT 0x prefix)
# NEVER use a wallet with real mainnet funds for testing
PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"

# Sepolia Testnet RPC URL (from Alchemy, Infura, etc.)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY"
