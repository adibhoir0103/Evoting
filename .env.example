# Hardhat Configuration
REPORT_GAS=false

# Testnet Deployment (Optional - Uncomment when deploying to testnet)
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_API_KEY
# PRIVATE_KEY=your_metamask_private_key_here

# Note: NEVER commit your actual .env file with real private keys!

# Backend Configuration
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-random-jwt-secret-here

# Admin credentials (change these before deploying to production)
# WARNING: The application falls back to 'admin123' if ADMIN_PASSWORD is not set.
# Always set a strong ADMIN_PASSWORD before deploying to production.
ADMIN_EMAIL=admin@evote.com
ADMIN_PASSWORD=your-strong-admin-password-here

# Email Service (required for OTP delivery)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Set to 'production' to disable demo OTP in API responses
NODE_ENV=development
