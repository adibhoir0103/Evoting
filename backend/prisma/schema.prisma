// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  fullname         String
  voter_id         String   @unique
  email            String   @unique
  password         String?
  aadhaar_number   String?  @unique
  mobile_number    String?
  wallet_address   String?
  has_voted        Boolean  @default(false)
  created_at       DateTime @default(now())
  father_name      String?
  gender           String?
  dob              String?
  state_code       Int      @default(0)
  constituency_code Int     @default(0)
  address          String?

  votes            Vote[]
}

model Vote {
  id           Int      @id @default(autoincrement())
  voter_id     String
  candidate_id Int
  tx_hash      String?
  voted_at     DateTime @default(now())

  user         User     @relation(fields: [voter_id], references: [voter_id])
}

model AdminAuditLog {
  id           Int      @id @default(autoincrement())
  admin_email  String
  action       String
  details      String?
  ip_address   String?
  created_at   DateTime @default(now())
}

model LoginHistory {
  id          Int      @id @default(autoincrement())
  voter_id    String
  ip_address  String?
  device_info String?
  login_time  DateTime @default(now())
  status      String   @default("SUCCESS") // SUCCESS, FAILED
}

model OtpDeliveryLog {
  id          Int      @id @default(autoincrement())
  recipient   String   // email or phone number
  purpose     String   // e.g., login, password-reset
  success     Boolean  @default(false)
  error_msg   String?
  sent_at     DateTime @default(now())
}

model State {
  id          Int      @id @default(autoincrement())
  code        Int      @unique
  name        String
  total_seats Int      @default(0)
}

model Constituency {
  id          Int      @id @default(autoincrement())
  code        Int      @unique
  state_code  Int
  name        String
  voters_count Int     @default(0)
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  user_id     String   // Maps to user's voter_id or email
  issue_type  String
  description String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  admin_reply String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}
