// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  VOTER
  SUPER_ADMIN
  ELECTION_OFFICER
  AUDITOR
}

enum ElectionStatus {
  DRAFT
  PUBLISHED
  AWAITING_APPROVAL
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

model User {
  id               Int      @id @default(autoincrement())
  auth_id          String?  @unique
  fullname         String
  voter_id         String   @unique
  email            String   @unique
  password         String?
  aadhaar_number   String?  @unique
  mobile_number    String?
  wallet_address   String?
  
  // Legacy global vote flag (deprecating in favor of ElectionVoter.has_voted)
  has_voted        Boolean  @default(false) 
  
  role             Role     @default(VOTER)
  created_at       DateTime @default(now())
  
  father_name      String?
  gender           String?
  dob              String?
  state_code       Int      @default(0)
  constituency_code Int     @default(0)
  address          String?

  votes            Vote[]
  election_voters  ElectionVoter[]
}

model Election {
  id              Int      @id @default(autoincrement())
  name            String
  description     String?
  instructions    String?
  start_time      DateTime?
  end_time        DateTime?
  status          ElectionStatus @default(DRAFT)
  rules           Json?
  created_at      DateTime @default(now())

  candidates      ElectionCandidate[]
  voters          ElectionVoter[]
  votes           Vote[]
}

model ElectionCandidate {
  id               Int      @id @default(autoincrement())
  election_id      Int
  candidate_name   String
  party_name       String?
  party_symbol     String?
  state_code       Int      @default(0)
  constituency_code Int     @default(0)

  election         Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
}

model ElectionVoter {
  id               Int      @id @default(autoincrement())
  election_id      Int
  user_id          Int
  has_voted        Boolean  @default(false)
  registration_time DateTime @default(now())

  election         Election @relation(fields: [election_id], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([election_id, user_id])
}

model Vote {
  id           Int      @id @default(autoincrement())
  voter_id     String   // Maps to User.voter_id
  election_id  Int?     // Made optional for legacy support migrating over
  tx_hash      String?
  voted_at     DateTime @default(now())

  user         User     @relation(fields: [voter_id], references: [voter_id])
  election     Election? @relation(fields: [election_id], references: [id])
}

model AdminAuditLog {
  id           Int      @id @default(autoincrement())
  admin_email  String
  action       String
  details      String?
  ip_address   String?
  created_at   DateTime @default(now())
}

model LoginHistory {
  id          Int      @id @default(autoincrement())
  voter_id    String
  ip_address  String?
  device_info String?
  login_time  DateTime @default(now())
  status      String   @default("SUCCESS") // SUCCESS, FAILED
}

model OtpDeliveryLog {
  id          Int      @id @default(autoincrement())
  recipient   String
  purpose     String
  success     Boolean  @default(false)
  error_msg   String?
  sent_at     DateTime @default(now())
}

model State {
  id          Int      @id @default(autoincrement())
  code        Int      @unique
  name        String
  total_seats Int      @default(0)
}

model Constituency {
  id          Int      @id @default(autoincrement())
  code        Int      @unique
  state_code  Int
  name        String
  voters_count Int     @default(0)
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  user_id     String
  issue_type  String
  description String
  status      String   @default("OPEN")
  admin_reply String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model KeystrokeProfile {
  id              Int      @id @default(autoincrement())
  user_email      String
  sample_count    Int      @default(0)
  hold_times      String   @default("[]")   // JSON array of average hold times per key position
  flight_times    String   @default("[]")   // JSON array of average inter-key delays
  mean_speed      Float    @default(0)      // Overall average typing speed (chars/sec)
  std_deviation   Float    @default(0)      // Standard deviation of timing pattern
  is_enrolled     Boolean  @default(false)  // True after MIN_SAMPLES collected
  last_verified   DateTime?
  last_score      Float?                    // Last comparison score (0 = perfect match, higher = suspicious)
  flagged_count   Int      @default(0)      // Number of times keystroke mismatch flagged
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([user_email])
}
