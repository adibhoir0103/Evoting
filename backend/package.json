{
    "name": "evoting-backend",
    "version": "1.0.0",
    "description": "Backend API for Bharat E-Vote blockchain voting system",
    "main": "server.js",
    "scripts": {
        "build": "npx prisma generate",
        "start": "npx prisma db push --accept-data-loss && node server.js",
        "dev": "nodemon server.js",
        "prod": "pm2 start ecosystem.config.js --env production",
        "test": "jest",
        "test:api": "jest tests/",
        "postinstall": "npx prisma generate"
    },
    "dependencies": {
        "@prisma/client": "^6.4.1",
        "@sentry/node": "^10.53.1",
        "@supabase/supabase-js": "^2.108.2",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.38.0",
        "axios": "^1.9.0",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.76.10",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "csv-parser": "^3.2.1",
        "dotenv": "^17.4.2",
        "ethers": "^6.16.0",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.1.0",
        "hpp": "^0.2.3",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "prisma": "^6.4.1",
        "sanitize-html": "^2.17.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "jest": "^30.4.2",
        "supertest": "^7.2.2"
    }
}
