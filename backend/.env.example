# ============================================================
# Bharat E-Vote Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# To generate a secure JWT secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# To generate admin password hash:
#   node -e "require('bcrypt').hash('YOUR_STRONG_PASSWORD', 12).then(console.log)"
# ============================================================

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Authentication ---
JWT_SECRET=""
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AADHAAR_PEPPER=""
# REQUIRED in production. Secret key to HMAC the Aadhaar PII deterministically. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# --- Admin Credentials ---
ADMIN_EMAIL="admin@evote.com"
ADMIN_PASSWORD_HASH=""
# Generate with: node -e "require('bcryptjs').hash('YOUR_STRONG_PASSWORD', 12).then(console.log)"
# Use a password with 16+ chars, uppercase, lowercase, numbers, and symbols.

# --- Supabase ---
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# --- Error Monitoring (Sentry) ---
SENTRY_DSN=""

# --- Email Service (Brevo) ---
# Sign up: https://app.brevo.com/
# Get API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
BREVO_FROM_EMAIL="no-reply@your-domain.com"
BREVO_FROM_NAME="Bharat E-Vote"

# --- Session Store (Upstash Redis) ---
# Sign up: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Bot Protection (Cloudflare Turnstile) ---
TURNSTILE_SECRET_KEY=""

# --- Optional: Blockchain ---
CONTRACT_ADDRESS=""
RPC_URL=""

# --- IPFS Storage (Pinata) ---
# Sign up: https://app.pinata.cloud/
# Note: Without these keys, the system silently falls back to local IPFS mock storage.
PINATA_API_KEY=""
PINATA_SECRET_KEY=""

# --- Environment ---
NODE_ENV="development"
PORT=5000

