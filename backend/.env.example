# ============================================
# Bharat E-Vote Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============ Supabase ============
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres"
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ============ Auth ============
JWT_SECRET="your-super-secure-jwt-secret-here"  # REQUIRED in production
ADMIN_EMAIL="admin@evote.com"                    # Admin login email
ADMIN_PASSWORD_HASH="$2a$10$..."                 # bcrypt hash of admin password (REQUIRED in production)
# To generate: node -e "console.log(require('bcrypt').hashSync('YourPassword', 10))"
ADMIN_DEV_PASSWORD="Admin@modern7"               # Dev-only fallback (ignored in production)
NODE_ENV="production"                            # Set to 'production' on Render/Vercel

# ============ Sentry Error Monitoring ============
SENTRY_DSN="https://xxx@xxx.ingest.us.sentry.io/xxx"

# ============ Resend Email Service ============
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ============ Upstash Redis (OTP + Rate Limiting) ============
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ============ Cloudflare Turnstile (Bot Protection) ============
TURNSTILE_SECRET_KEY="0x4AAAAAxxxxxxxxxx"
