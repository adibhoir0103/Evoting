            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ELECTION_OFFICER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users/1/role",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "users", "1", "role"]
            },
            "description": "Assigns a role to a user. Only SUPER_ADMIN can do this. Valid roles: VOTER, SUPER_ADMIN, ELECTION_OFFICER, AUDITOR."
          },
          "response": []
        },
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/audit",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "audit"]
            },
            "description": "Returns the last 100 admin audit log entries (login, election changes, voter modifications, etc.)."
          },
          "response": []
        }
      ]
    },
