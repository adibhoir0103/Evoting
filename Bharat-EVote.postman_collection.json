    {
      "name": "🗳️ Voting",
      "item": [
        {
          "name": "1. Pre-Flight Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/vote/pre-flight",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "vote", "pre-flight"]
            },
            "description": "Step 1: Generates a single-use 5-minute vote token stored in Upstash Redis. Must be called before casting a vote."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (json.upstashToken) {",
                  "        pm.collectionVariables.set('vote_preflight_token', json.upstashToken);",
                  "        console.log('✅ Pre-flight token saved: ' + json.upstashToken.substring(0, 12) + '...');",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Record Vote",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"txHash\": \"0xabc123def456789...\",\n  \"upstashToken\": \"{{vote_preflight_token}}\",\n  \"turnstileToken\": \"turnstile-not-configured\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/vote/record",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "vote", "record"]
            },
            "description": "Step 2: Records the vote after blockchain transaction. Uses the pre-flight token from Step 1. The token is burned after use."
          },
          "response": []
        },
        {
          "name": "3. Vote Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/vote/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "vote", "status"]
            },
            "description": "Check if the current user has already voted."
          },
          "response": []
        },
        {
          "name": "4. Vote Receipt",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/vote/receipt",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "vote", "receipt"]
            },
            "description": "Retrieves the vote receipt (tx_hash and timestamp) for the dashboard."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔑 Admin",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@evote.com\",\n  \"password\": \"Admin@modern7\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "login"]
            },
            "description": "Authenticates admin and returns JWT. Token auto-saved to collection variable `admin_token`.\n\n⚠️ Rate limited: 5 attempts per 15 minutes."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login successful', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.collectionVariables.set('admin_token', json.token);",
                  "    console.log('✅ Admin JWT saved to {{admin_token}}');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Admin Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "stats"]
            },
            "description": "Dashboard overview: total users, votes, elections, turnout percentage, and last 10 audit log entries."
          },
          "response": []
        },
        {
          "name": "Get All Elections",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/elections",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "elections"]
            },
            "description": "Lists all elections with candidate/voter/vote counts."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    if (Array.isArray(json) && json.length > 0) {",
                  "        pm.collectionVariables.set('election_id', json[0].id.toString());",
                  "        console.log('✅ election_id set to: ' + json[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Election",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Council Election 2026\",\n  \"description\": \"Annual student body president and council election\",\n  \"instructions\": \"Vote for one candidate per position. Verify your identity before voting.\",\n  \"start_time\": \"2026-04-15T09:00:00.000Z\",\n  \"end_time\": \"2026-04-15T17:00:00.000Z\",\n  \"rules\": {\n    \"maxVotesPerUser\": 1,\n    \"requireIdentityVerification\": true\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/elections",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "elections"]
            },
            "description": "Creates a new election in DRAFT status."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('election_id', json.id.toString());",
                  "    console.log('✅ New election_id saved: ' + json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Election Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/elections/{{election_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "elections", "{{election_id}}", "status"]
            },
            "description": "Transitions election through lifecycle: DRAFT → PUBLISHED → AWAITING_APPROVAL → ACTIVE → PAUSED/CLOSED → ARCHIVED.\n\nOnly SUPER_ADMIN can activate. PAUSED/CLOSED require override_reason."
          },
          "response": []
        },
        {
          "name": "Add Candidate to Election",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidate_name\": \"Rahul Sharma\",\n  \"party_name\": \"Student Progressive Alliance\",\n  \"party_symbol\": \"🌟\",\n  \"state_code\": 27,\n  \"constituency_code\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/elections/{{election_id}}/candidates",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "elections", "{{election_id}}", "candidates"]
            },
            "description": "Adds a candidate to a DRAFT election. Cannot modify ballot after draft phase (zero-trust guardrail)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('candidate_id', json.id.toString());",
                  "    console.log('✅ candidate_id saved: ' + json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Candidate from Election",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/elections/{{election_id}}/candidates/{{candidate_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "elections", "{{election_id}}", "candidates", "{{candidate_id}}"]
            },
            "description": "Removes a candidate from a DRAFT election. Forbidden after draft phase."
          },
          "response": []
        },
        {
          "name": "Upload Voters CSV",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "CSV file with columns: aadhaar_number, email, or voter_id"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/elections/{{election_id}}/voters/upload",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "elections", "{{election_id}}", "voters", "upload"]
            },
            "description": "Uploads a CSV file to whitelist voters for a specific election. CSV columns: aadhaar_number, email, voter_id (any one)."
          },
          "response": []
        },
        {
          "name": "Broadcast Email to Voters",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Election Day Reminder\",\n  \"body\": \"Voting for Student Council Election 2026 opens tomorrow at 9:00 AM. Please have your Voter ID ready.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/elections/{{election_id}}/notify",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "elections", "{{election_id}}", "notify"]
            },
            "description": "Sends a broadcast notification email via QStash to all voters in an election."
          },
          "response": []
        },
        {
          "name": "Get All Admins",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/admins",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "admins"]
            },
            "description": "Lists all users with admin roles (SUPER_ADMIN, ELECTION_OFFICER, AUDITOR)."
          },
          "response": []
        },
        {
