          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('zkp_commitment', json.commitment);",
                  "    pm.collectionVariables.set('zkp_randomness', json.randomness);",
                  "    console.log('✅ Commitment saved: ' + json.commitment.substring(0, 16) + '...');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Generate Nullifier",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"voterSecret\": \"my-secret-voter-key-12345\",\n  \"electionId\": \"bharat-evote-2026\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/zkp/generate-nullifier",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zkp", "generate-nullifier"]
            },
            "description": "Step 2: Generates a nullifier hash and identity commitment from a voter secret. Prevents double-voting."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('zkp_nullifier', json.nullifierHash);",
                  "    console.log('✅ Nullifier saved: ' + json.nullifierHash.substring(0, 16) + '...');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Generate Proof",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidateId\": 1,\n  \"randomness\": \"{{zkp_randomness}}\",\n  \"candidatesCount\": 5,\n  \"commitment\": \"{{zkp_commitment}}\",\n  \"nullifierHash\": \"{{zkp_nullifier}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/zkp/generate-proof",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zkp", "generate-proof"]
            },
            "description": "Step 3: Generates a Schnorr zero-knowledge proof. Requires commitment, randomness, and nullifier from Steps 1-2."
          },
          "response": []
        },
        {
          "name": "4. Verify Proof",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"commitment\": \"{{zkp_commitment}}\",\n  \"nullifierHash\": \"{{zkp_nullifier}}\",\n  \"proof\": [\"0xabc\", \"0xdef\"],\n  \"candidatesCount\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/zkp/verify-proof",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "zkp", "verify-proof"]
            },
            "description": "Step 4: Verifies a ZK proof. Public endpoint (no auth required). Rate limited to prevent proof-grinding."
          },
          "response": []
