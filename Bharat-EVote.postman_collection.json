              "raw": "{\n  \"fullname\": \"Aditya Bhoir\",\n  \"voterId\": \"MH-VOT-001\",\n  \"aadhaarNumber\": \"123456789012\",\n  \"mobileNumber\": \"9876543210\",\n  \"stateCode\": 27,\n  \"constituencyCode\": 1,\n  \"email\": \"voter@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register-clerk",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register-clerk"]
