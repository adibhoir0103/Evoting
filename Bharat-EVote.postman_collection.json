{
  "info": {
    "name": "Bharat E-Vote API",
    "_postman_id": "bharat-evote-2026",
    "description": "Complete API collection for the Bharat E-Vote blockchain-based e-voting platform.\n\nIncludes: Auth, Voting, Admin, ZKP, IPFS, Keystroke Dynamics, and Meta-Tx endpoints.\n\n**Setup:**\n1. Import this collection\n2. Import the companion environment file OR create variables: `base_url`, `admin_token`\n3. Run 'Admin Login' first to auto-populate the admin JWT token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "election_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "candidate_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "vote_preflight_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "zkp_commitment",
      "value": "",
      "type": "string"
    },
    {
      "key": "zkp_randomness",
      "value": "",
      "type": "string"
    },
    {
      "key": "zkp_nullifier",
      "value": "",
      "type": "string"
    },
    {
      "key": "ipfs_hash",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Returns server status, version, uptime, and available endpoint prefix."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Server is running', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('running');",
                  "    pm.expect(json.service).to.include('Bharat E-Vote');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Check Voter Eligibility",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"voter@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/check-eligibility",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "check-eligibility"]
            },
            "description": "Checks if an email is in the approved voter whitelist before allowing Clerk signup. Rate limited: 10 req/min."
          },
          "response": []
        },
        {
          "name": "Register Clerk User",
          "request": {
